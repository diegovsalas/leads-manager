# Copiar a .env y llenar con valores reales
# SECRET_KEY, META_VERIFY_TOKEN y BOT_SECRET son obligatorias: la app no
# arranca sin ellas (antes tenían defaults hardcodeados e inseguros).
SECRET_KEY=cambiar-por-algo-largo-y-aleatorio
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres
WHATSAPP_TOKEN=EAAxxxxxxx
WHATSAPP_PHONE_ID=1234567890
META_VERIFY_TOKEN=mi_token_secreto
# App Secret de la app de Meta (Meta Developer Console > Settings > Basic).
# Se usa para validar la firma X-Hub-Signature-256 del webhook /webhook/meta.
META_APP_SECRET=
# Compartido con el microservicio whatsapp-bot (mismo valor en ambos Render services).
BOT_SECRET=cambiar-por-algo-largo-y-aleatorio
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=https://leads-manager-avantex.onrender.com/auth/google/callback

# Resend (correos transaccionales: notificaciones diarias, cotizaciones,
# confirmación de tickets del portal público). Sin esta key esos envíos
# se saltan con gracia, no truenan.
RESEND_API_KEY=

# Supabase Storage (fotos adjuntas a tickets del portal público, bucket
# ticket-evidencia). Mismo proyecto/credenciales que DATABASE_URL.
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=

# Savio (cobranza / suscripciones — solo lectura)
SAVIO_BASE_URL=https://api.savio.mx/api/v1
SAVIO_API_KEY=
SAVIO_WEBHOOK_SECRET=

# SDR Prospector — búsqueda de prospectos en Maps + Meta Ads
GOOGLE_PLACES_API_KEY=
META_ACCESS_TOKEN=

# SDR Directivo — Apollo (búsqueda B2B), Lusha (enriquecimiento), Lemlist (outreach)
APOLLO_API_KEY=
LUSHA_API_KEY=
LEMLIST_API_KEY=
DOMAIN=https://leads-manager-avantex.onrender.com

# Aircall (telefonía)
AIRCALL_API_ID=
AIRCALL_API_TOKEN=

# Zoho CRM
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=https://leads-manager-avantex.onrender.com/api/zoho/auth/zoho/callback

# Chatbot (Anthropic + WhatsApp Cloud API)
ANTHROPIC_API_KEY=

# SCIP — Meta Ads (no requiere SDK, usa Graph API directo)
META_API_VERSION=v19.0
META_APP_ID=
META_ACCOUNT_B2C=
META_ACCOUNT_B2B=
META_ACCOUNT_WELDU=

# SCIP — Google Ads (requiere SDK google-ads, ya en requirements.txt)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
